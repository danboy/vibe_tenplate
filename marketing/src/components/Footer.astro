---
import { links } from '../config';
---

<footer class="bg-brand-dark-surface dark:bg-brand-dark-bg border-t border-brand-dark-border-sub text-brand-dark-text-muted py-12 px-6 transition-colors duration-200">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between gap-8 mb-10">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/logo.svg" alt="10plate logo" class="w-8 h-8" />
          <span class="font-bold text-brand-dark-text text-lg">10plate</span>
        </div>
        <p class="text-sm max-w-xs leading-relaxed">
          The collaborative planning canvas for teams who think together.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 text-sm">
        <div>
          <h4 class="text-brand-dark-text font-semibold mb-3">Product</h4>
          <ul class="space-y-2">
            <li><a href="#features" class="hover:text-brand-dark-primary transition-colors">Features</a></li>
            <li><a href="#pricing" class="hover:text-brand-dark-primary transition-colors">Pricing</a></li>
            <li><a href="#how-it-works" class="hover:text-brand-dark-primary transition-colors">How it works</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-brand-dark-text font-semibold mb-3">Account</h4>
          <ul class="space-y-2">
            <li><a href={links.login} class="hover:text-brand-dark-primary transition-colors">Sign in</a></li>
            <li><a href={links.register} class="hover:text-brand-dark-primary transition-colors">Register</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-brand-dark-text font-semibold mb-3">Legal</h4>
          <ul class="space-y-2">
            <li><a href="/privacy" class="hover:text-brand-dark-primary transition-colors">Privacy</a></li>
            <li><a href="/terms" class="hover:text-brand-dark-primary transition-colors">Terms</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-brand-dark-border-sub pt-6 flex flex-col md:flex-row justify-between items-center gap-2 text-xs">
      <p>&copy; {new Date().getFullYear()} 10plate. All rights reserved.</p>
    </div>
  </div>
</footer>
