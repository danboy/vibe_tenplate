---
---

<section class="pt-32 pb-20 px-6 bg-gradient-to-b from-brand-bg to-white dark:from-brand-dark-surface dark:to-brand-dark-bg transition-colors duration-200">
  <div class="max-w-4xl mx-auto text-center">
    <img src="/logo.svg" alt="10plate" class="w-40 h-40 mx-auto mb-6" />

    <div class="inline-flex items-center gap-2 bg-brand-primary/10 text-brand-primary dark:text-brand-dark-primary text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
      <span class="w-2 h-2 bg-brand-primary dark:bg-brand-dark-primary rounded-full animate-pulse"></span>
      Built for teams who move fast
    </div>

    <h1 class="text-5xl md:text-6xl font-extrabold text-brand-text dark:text-brand-dark-text leading-tight mb-6">
      Plan together.<br />
      <span class="text-brand-primary dark:text-brand-dark-primary">Build together.</span>
    </h1>

    <p class="text-xl text-brand-text-muted dark:text-brand-dark-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      10plate gives your team an infinite canvas to brainstorm ideas, organise them into groups,
      and present a clear plan — all in real time.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/register"
        class="w-full sm:w-auto text-base font-semibold bg-brand-primary text-white px-8 py-3.5 rounded-xl hover:bg-brand-primary-dark transition-colors shadow-lg shadow-brand-primary/25"
      >
        Start for free
      </a>
      <a
        href="#how-it-works"
        class="w-full sm:w-auto text-base font-semibold text-brand-text-muted dark:text-brand-dark-text-muted px-8 py-3.5 rounded-xl border border-brand-border dark:border-brand-dark-border hover:border-brand-primary/40 dark:hover:border-brand-dark-primary/40 hover:bg-brand-surface dark:hover:bg-brand-dark-surface-hi transition-colors"
      >
        See how it works
      </a>
    </div>

    <p class="mt-4 text-sm text-brand-text-muted/60 dark:text-brand-dark-text-muted/60">No credit card required &middot; Free forever plan</p>
  </div>

  <!-- Canvas mockup -->
  <div class="max-w-5xl mx-auto mt-16 relative">
    <div class="rounded-2xl border border-brand-border dark:border-brand-dark-border shadow-2xl overflow-hidden bg-brand-bg dark:bg-brand-dark-surface transition-colors duration-200">
      <!-- Fake browser chrome -->
      <div class="bg-white dark:bg-brand-dark-surface-hi border-b border-brand-border dark:border-brand-dark-border-sub px-4 py-3 flex items-center gap-2 transition-colors duration-200">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
        <div class="flex-1 mx-4 bg-brand-surface dark:bg-brand-dark-bg rounded-md h-6 flex items-center px-3">
          <span class="text-xs text-brand-text-muted dark:text-brand-dark-text-muted">app.10plate.io/groups/product-team/q3-planning</span>
        </div>
      </div>
      <!-- Canvas area -->
      <div class="p-8 min-h-72 relative grid grid-cols-3 gap-4">
        <div class="bg-yellow-100 dark:bg-yellow-900/40 rounded-xl p-4 shadow-md rotate-1 hover:-rotate-0 transition-transform">
          <p class="text-sm font-medium text-yellow-800 dark:text-yellow-200">User onboarding flow redesign</p>
        </div>
        <div class="bg-brand-primary-container/60 dark:bg-brand-primary/20 rounded-xl p-4 shadow-md -rotate-1 hover:rotate-0 transition-transform">
          <p class="text-sm font-medium text-brand-primary-dark dark:text-brand-dark-primary">API rate limiting strategy</p>
        </div>
        <div class="bg-green-100 dark:bg-green-900/40 rounded-xl p-4 shadow-md rotate-2 hover:rotate-0 transition-transform">
          <p class="text-sm font-medium text-green-800 dark:text-green-200">Mobile push notifications</p>
        </div>
        <div class="bg-pink-100 dark:bg-pink-900/40 rounded-xl p-4 shadow-md -rotate-2 hover:rotate-0 transition-transform">
          <p class="text-sm font-medium text-pink-800 dark:text-pink-200">Improve search relevance</p>
        </div>
        <div class="bg-brand-primary-container/40 dark:bg-brand-dark-primary/10 rounded-xl p-4 shadow-md rotate-1 hover:rotate-0 transition-transform col-span-1">
          <p class="text-sm font-medium text-brand-primary dark:text-brand-dark-primary">Analytics dashboard v2</p>
        </div>
        <div class="bg-orange-100 dark:bg-orange-900/40 rounded-xl p-4 shadow-md -rotate-1 hover:rotate-0 transition-transform">
          <p class="text-sm font-medium text-orange-800 dark:text-orange-200">SSO / enterprise auth</p>
        </div>
      </div>
    </div>
  </div>
</section>
