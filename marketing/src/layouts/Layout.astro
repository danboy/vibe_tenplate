---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '10plate — Plan Together, Build Together',
  description = '10plate is the collaborative planning tool that helps teams brainstorm, organize, and present ideas on an infinite canvas.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <!-- Theme: applied before render to prevent flash -->
    <script is:inline>
      (function () {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');

        function applyTheme() {
          var saved;
          try { saved = localStorage.getItem('theme'); } catch (e) {}
          var shouldBeDark = saved === 'dark' || (!saved && mq.matches);
          document.documentElement.classList.toggle('dark', shouldBeDark);
        }

        applyTheme();
        mq.addEventListener('change', applyTheme);
        // Re-apply after HMR updates replace the DOM
        document.addEventListener('DOMContentLoaded', applyTheme);
      })();
    </script>
  </head>
  <body class="font-sans bg-brand-bg dark:bg-brand-dark-bg text-brand-text dark:text-brand-dark-text antialiased transition-colors duration-200">
    <slot />
  </body>
</html>
